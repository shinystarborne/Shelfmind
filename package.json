{
  "name": "shelfmind",
  "version": "1.4.2",
  "author": "Shiny Starborne",
  "description": "Your personal ebook library, beautifully organised",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder",
    "release": "npm run build && electron-builder --publish always"
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "cors": "^2.8.5",
    "electron-updater": "^6.8.9",
    "express": "^4.18.2",
    "fast-xml-parser": "^4.3.4",
    "iconv-lite": "^0.7.3",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^4.10.38",
    "qrcode": "^1.5.3",
    "word-extractor": "^1.0.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "fuse.js": "^7.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.10.3",
    "vite": "^5.0.12",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.shelfmind.app",
    "productName": "ShelfMind",
    "copyright": "Shiny",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "signingHashAlgorithms": [],
      "forceCodeSigning": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ShelfMind"
    },
    "npmRebuild": false,
    "publish": {
      "provider": "github",
      "owner": "shinystarborne",
      "repo": "Shelfmind",
      "releaseType": "release"
    }
  }
}
